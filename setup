#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

bootstrap_config() {
  if [[ -f "$_script_dir/config.sh" ]]; then
    # shellcheck source=config.sh
    source "$_script_dir/config.sh"
    return
  fi
  if [[ -f "$HOME/.obsidian_android_sync_state/bin/config.sh" ]]; then
    # shellcheck source=config.sh
    source "$HOME/.obsidian_android_sync_state/bin/config.sh"
    return
  fi

  export STORAGE_PATH="/storage/emulated/0"
  export NOTIFICATION_PATH="$STORAGE_PATH/sync-error-notification"
  STATE_DIR="$HOME/.obsidian_android_sync_state"
  INSTALL_BIN="$STATE_DIR/bin"
  export SCRIPTS_REPO_PATH="${SCRIPTS_REPO_PATH:-$_script_dir}"
  export OBSIDIAN_DIR_PATH="${OBSIDIAN_DIR_PATH:-/storage/emulated/0/repos/Obsidian}"
  mkdir -p "$STATE_DIR/tmp" "$STATE_DIR/git-repos" "$INSTALL_BIN"
  export LOCK_FILE="$STATE_DIR/sync-vaults.lock"
  export LOG_FILE="$STATE_DIR/sync.log"
  export SYNC_TMP_DIR="$STATE_DIR/tmp"
  export GIT_REPOS_PATH="$STATE_DIR/git-repos"
  export RESET="\033[0m" GREEN="\033[1;32m" RED="\033[1;31m" BLUE="\033[1;34m" YELLOW="\033[1;33m"

  if [[ ! -f "$STATE_DIR/.env" && -f "$SCRIPTS_REPO_PATH/.env.example" ]]; then
    cp "$SCRIPTS_REPO_PATH/.env.example" "$STATE_DIR/.env"
    set -a
    # shellcheck source=/dev/null
    source "$STATE_DIR/.env"
    set +a
  elif [[ -f "$STATE_DIR/.env" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$STATE_DIR/.env"
    set +a
  fi
}

bootstrap_config

enable_allow_external_apps() {
  local props="$HOME/.termux/termux.properties"
  mkdir -p "$(dirname "$props")"
  if grep -qE '^[[:space:]]*allow-external-apps[[:space:]]*=[[:space:]]*true' "$props" 2>/dev/null; then
    return 0
  fi
  if grep -qE '^[[:space:]]*#[[:space:]]*allow-external-apps[[:space:]]*=[[:space:]]*true' "$props" 2>/dev/null; then
    sed -i 's/^[[:space:]]*#[[:space:]]*allow-external-apps[[:space:]]*=[[:space:]]*true/allow-external-apps = true/' "$props"
  else
    echo 'allow-external-apps = true' >> "$props"
  fi
  termux-reload-settings
}

### Update scripts repo

cd "$SCRIPTS_REPO_PATH"
git fetch > /dev/null
git_status=$(git status)

if [[ "$git_status" == *"Your branch is behind"* ]]; then
  if [[ "$git_status" == *"Changes not staged for commit"* || "$git_status" == *"Changes to be committed"* ]]; then
    echo -e "${RED}There are local changes in the scripts repo which would block a git pull. Just be aware that you're missing updates. Continuing script...${RESET}"
  else
    if git pull > /dev/null 2>&1; then
      echo -e "${GREEN}Updated the scripts repo!${RESET}"
    else
      echo -e "${RED}Failed to update the scripts repo.${RESET}"
      exit 1
    fi
  fi
fi

### Make sure Termux has file permissions

if touch "$STORAGE_PATH/.termux_permission_check"; then
  rm "$STORAGE_PATH/.termux_permission_check"
else
  echo -e "${RED}Termux does not have file permissions.${RESET}"
  echo -e "${BLUE}Run 'termux-setup-storage' or give the permission from Termux's permissions menu on Android.${RESET}"
fi

### Enable allow-external-apps (idempotent)

enable_allow_external_apps

### Install to STATE_DIR/bin

INSTALL_ARTIFACTS=(
  config.sh
  env.sh
  setup
  sync-vaults.sh
  list-log.sh
  vaults-status.sh
  open-vault.sh
  git-sync
  worktree-fix.sh
  log_helper.sh
  migrate-from-legacy.sh
)

mkdir -p "$INSTALL_BIN"
for artifact in "${INSTALL_ARTIFACTS[@]}"; do
  if [[ ! -f "$SCRIPTS_REPO_PATH/$artifact" ]]; then
    echo -e "${RED}Missing $SCRIPTS_REPO_PATH/$artifact${RESET}" >&2
    exit 1
  fi
  cp "$SCRIPTS_REPO_PATH/$artifact" "$INSTALL_BIN/"
  chmod +x "$INSTALL_BIN/$artifact"
done

# Re-source config from installed location
# shellcheck source=config.sh
source "$INSTALL_BIN/config.sh"

if [[ ! -f "$STATE_DIR/.env" ]]; then
  cp "$SCRIPTS_REPO_PATH/.env.example" "$STATE_DIR/.env"
  set -a
  # shellcheck source=/dev/null
  source "$STATE_DIR/.env"
  set +a
fi

### Make sure user.name and user.email is populated

git_name=$(git config --global user.name 2>/dev/null || true)
git_email=$(git config --global user.email 2>/dev/null || true)

if [[ -z "$git_name" ]]; then
  read -p "Enter your git user.name: " git_name
  git config --global user.name "$git_name"
fi

if [[ -z "$git_email" ]]; then
  read -p "Enter your git user.email: " git_email
  git config --global user.email "$git_email"
fi

touch "$NOTIFICATION_PATH"

cd "$OBSIDIAN_DIR_PATH"

echo -e "\n${GREEN}Setup complete${RESET}"
echo -e "Scripts installed to: ${BLUE}$INSTALL_BIN${RESET}"
echo -e "Config: ${BLUE}$STATE_DIR/.env${RESET}"
echo -e "Optional shell shortcuts: ${BLUE}source $INSTALL_BIN/env.sh${RESET} (add to your ~/.bashrc)"
echo -e "Re-import the Tasker project from this repo's Obsidian_Syncing.prj.xml"
if [[ ! -f "$HOME/.ssh/id_rsa" ]]; then
  echo -e "${YELLOW}Create an SSH key before cloning vaults — see README${RESET}"
fi
echo -e "Upgrading from an old install? Run: ${BLUE}$INSTALL_BIN/migrate-from-legacy.sh${RESET}\n"
